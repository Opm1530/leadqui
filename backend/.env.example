# ── Banco de Dados PostgreSQL ─────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/pequi_digital"

# ── Auth JWT ─────────────────────────────────────────────────────────
JWT_SECRET="troque-por-uma-chave-secreta-muito-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"

# ── Servidor ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── Resend (E-mail para reset de senha) ──────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@pequidigital.com.br"

# ── Evolution API ─────────────────────────────────────────────────────
# (Configurado por usuário via settings — campo opcional global)
EVOLUTION_API_URL_GLOBAL=""
