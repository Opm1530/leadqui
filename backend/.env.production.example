# ── Banco de Dados ────────────────────────────────────────────────────
# Na VPS use o nome do container: docker-postgres-1
DATABASE_URL="postgresql://USUARIO:SENHA@docker-postgres-1:5432/pequi"

# ── Servidor ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://leadqui.vps.pequi.digital"

# ── Auth JWT ──────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET="TROQUE_POR_UMA_CHAVE_FORTE"
JWT_EXPIRES_IN="7d"

# ── Cofre de Senhas (AES-256-GCM) ─────────────────────────────────────
# Gere com: openssl rand -hex 32
VAULT_ENCRYPTION_KEY="TROQUE_POR_UMA_CHAVE_DE_32_BYTES_HEX"

# ── E-mail (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="noreply@pequi.digital"

# ── Meta / Facebook OAuth ─────────────────────────────────────────────
META_OAUTH_REDIRECT_URI="https://leadqui.vps.pequi.digital/api/techqui/oauth/callback"
META_WEBHOOK_VERIFY_TOKEN="pequi_webhook_2026"

# ── Instagram Business Login OAuth ────────────────────────────────────
INSTAGRAM_OAUTH_REDIRECT_URI="https://leadqui.vps.pequi.digital/api/techqui/oauth/instagram/callback"
